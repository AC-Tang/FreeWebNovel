<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.freefiction.mapper.RankingsMapper">

    <resultMap id="BaseResultMap" type="com.example.freefiction.entity.Rankings">
            <id property="id" column="id" />
            <result property="bookId" column="book_id" />
            <result property="rankingType" column="ranking_type" />
            <result property="rankValue" column="rank_value" />
            <result property="rankPosition" column="rank_position" />
            <result property="statDate" column="stat_date" />
            <result property="createdAt" column="created_at" />
    </resultMap>

    <sql id="Base_Column_List">
        id,book_id,ranking_type,rank_value,rank_position,stat_date,
        created_at
    </sql>
</mapper>
