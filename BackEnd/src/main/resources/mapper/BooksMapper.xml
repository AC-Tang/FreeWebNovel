            <result property="subtitle" column="subtitle" />
            <result property="author" column="author" />
            <result property="categoryId" column="category_id" />
            <result property="cover" column="cover" />
            <result property="description" column="description" />
            <result property="status" column="status" />
            <result property="wordCount" column="word_count" />
            <result property="chapterCount" column="chapter_count" />
            <result property="viewCount" column="view_count" />
            <result property="recommendCount" column="recommend_count" />
            <result property="ratingAvg" column="rating_avg" />
            <result property="ratingCount" column="rating_count" />
            <result property="lastChapterTitle" column="last_chapter_title" />
            <result property="lastChapterTime" column="last_chapter_time" />
            <result property="publishDate" column="publish_date" />
            <result property="createdAt" column="created_at" />
            <result property="updatedAt" column="updated_at" />
    </resultMap>

    <sql id="Base_Column_List">
        id,title,subtitle,author,category_id,cover,
        description,status,word_count,chapter_count,view_count,
        recommend_count,rating_avg,rating_count,last_chapter_title,last_chapter_time,
        publish_date,created_at,updated_at
    </sql>
</mapper>
