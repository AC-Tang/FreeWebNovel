<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.freefiction.mapper.BooksMapper">

    <resultMap id="BaseResultMap" type="com.example.freefiction.entity.Books">
            <id property="id" column="id" />
